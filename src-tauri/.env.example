# OANDA API Configuration
# Copy this file to .env

# Your OANDA API key (get from OANDA developer portal)
OANDA_API_KEY=your-api-key-here

# Your OANDA account ID (found in your OANDA account settings)
OANDA_ACCOUNT_ID=your-account-id-here

# Environment: "practice" for demo account, "live" for real trading
OANDA_ENVIRONMENT=practice

# PostgreSQL connection string (same as Railway)
DATABASE_URL=postgresql://user:password@host:port/database

# Anthropic API key (optional - enables AI strategy generation)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
