{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wickd",
  "version": "0.21.0",
  "identifier": "com.openthink.wickd",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "wickd",
        "url": "index.html?window=local",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob: https://*.tauri.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:* ipc: http://ipc.localhost https://*.tauri.localhost https://api-fxpractice.oanda.com https://api-fxtrade.oanda.com https://stream-fxpractice.oanda.com https://stream-fxtrade.oanda.com; img-src 'self' data:; frame-src https://*.tauri.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-iconTemplate.png",
      "icons/tray-iconTemplate@2x.png"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "Developer ID Application: Matt Pardini (B2B36MFVKQ)"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhENEI1NDk5MTNDOEE5MzgKUldRNHFjZ1RtVlJMamZWbkYxRDBIdmx5bmtwMzJ2RDl1KzhSL1NnTXlza052cjVTdlhVV3YrTzMK",
      "endpoints": [
        "https://localhost/updates/latest.json"
      ]
    }
  }
}
