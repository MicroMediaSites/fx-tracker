{
  "name": "wickd",
  "version": "0.2.24",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:app": "npm run tauri dev",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "tauri": "tauri",
    "test:be": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:be:cov": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest",
    "test:ui:cov": "vitest run --coverage",
    "test": "npm run test:be && npm run test:ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "reset-windows": "rm -f \"$HOME/Library/Application Support/com.openthink.wickd/.window-state.json\" && echo 'Window state cleared'"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.1.18",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "4.4.1",
    "concurrently": "9.2.1",
    "dotenv": "16.0.0",
    "jsdom": "27.4.0",
    "puppeteer": "^24.38.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite": "5.4.21",
    "vitest": "4.0.17"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.21.5",
    "@rollup/rollup-linux-x64-gnu": "4.56.0",
    "@rollup/rollup-linux-x64-musl": "4.56.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.18",
    "@tailwindcss/oxide-linux-x64-musl": "4.1.18",
    "lightningcss-linux-x64-gnu": "1.31.1",
    "lightningcss-linux-x64-musl": "1.31.1"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-shell": "2.3.3",
    "@tauri-apps/plugin-updater": "2.9.0",
    "lightweight-charts": "5.0.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "wouter": "3.7.1",
    "zod": "3.23.0",
    "zustand": "5.0.9"
  }
}
